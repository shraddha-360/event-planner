<div x-data="{ mobileNav: false }">

<header class="w-full bg-white border-b-4 border-blue-200 sticky top-0 z-50 shadow-sm"
style="background-color: {{ header.headerBgColor }};">

    <div class="max-w-[1200px] mx-auto px-4 flex items-center justify-between h-20">

        <!-- Logo -->
        <a href="/" class="text-2xl font-bold text-blue-700 tracking-wide hover:text-blue-800 transition">
            Plannix
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center space-x-8 {{header.navActiveStyle}}">
            {% include '_includes/desktopNav' %}
        </nav>

        <!-- CTA Button -->
       
	<div class="hidden lg:block">
		<a href="{{ header.ctaLink.url() ?? '#' }}" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md hover:shadow-lg">
			{{ header.ctaButton }}
		</a>
	</div>

        <!-- Hamburger -->
        <button @click="mobileNav = !mobileNav"
                class="lg:hidden text-gray-700 focus:outline-none">

            <!-- Burger -->
            <svg x-show="!mobileNav" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4 6h16M4 12h16M4 18h16"/>
            </svg>

            <!-- Close -->
            <svg x-show="mobileNav" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M6 18L18 6M6 6l12 12"/>
            </svg>

        </button>

    </div>

</header>

{% include '_includes/mobileNav' %}

</div>