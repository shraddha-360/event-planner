{% set images = block.imageGallery.all() %}

<section class="py-10">
	<div class="max-w-7xl mx-auto px-4">

		<div class="text-center font-bold text-5xl py-12">
			Image Gallery
		</div>

		<!-- GRID -->
		<div class="grid grid-cols-2 md:grid-cols-4" x-data="gallery()">

			{% for img in images %}
				<div class="relative cursor-pointer group overflow-hidden" @click="open({{ loop.index0 }})">

					<img src="{{ img.url }}" class="w-full h-60 object-cover">

					<div class="absolute inset-0 bg-red-500/70 opacity-0 group-hover:opacity-100 flex
																					                     items-center justify-center transition">

						<span class="text-white text-3xl">+</span>
					</div>

				</div>

			{% endfor %}
			<!-- LIGHTBOX -->
			<div
				x-show="show" x-transition class="fixed inset-0 bg-black/90 flex items-center justify-center z-50">

				<!-- CLOSE -->
				<button @click="show = false" class="absolute top-5 right-5 text-white text-3xl">
					✕
				</button>

				<!-- PREV -->
				<button @click="prev()" class="absolute left-5 text-white text-4xl">
					‹
				</button>

				<!-- IMAGE -->
				<img
				:src="images[current]" class="max-h-[80vh] max-w-[90vw] object-contain rounded">

				<!-- NEXT -->
				<button @click="next()" class="absolute right-5 text-white text-4xl">
					›
				</button>

			</div>

		</div>

	</div>
</section>

<script>
	function gallery() {
return {
show: false,
current: 0,

images: [{% for image in images %}"{{ image.url }}",{% endfor %}],

open(index) {
this.current = index
this.show = true
},

next() {
this.current = (this.current + 1) % this.images.length
},

prev() {
this.current = (this.current - 1 + this.images.length) % this.images.length
}
}
}
</script>
